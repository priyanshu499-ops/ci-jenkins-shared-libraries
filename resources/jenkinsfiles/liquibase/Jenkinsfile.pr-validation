// =============================================================================
//  Jenkinsfile.pr-validation
//  Path in repo: resources/jenkinsfiles/liquibase/Jenkinsfile.pr-validation
//
//  Trigger:  Pull Request event (GitHub Webhook)
//  Job type: Pipeline Job
//  SCM:      https://github.com/priyanshu499-ops/ci-jenkins-shared-libraries.git
//  Branch:   liquibase
//  Script:   resources/jenkinsfiles/liquibase/Jenkinsfile.pr-validation
//
// =============================================================================

@Library('ci-jenkins-shared-libraries@liquibase') _

node('built-in') {

    stage('Git Checkout') {
        echo "Workspace already has ci-jenkins-shared-libraries files"
        echo "Liquibase files location: ${WORKSPACE}/liquibase/"
        checkout scm
    }

    stage('Liquibase Validate') {
        withCredentials([
            string(credentialsId: 'LIQUIBASE_URL',      variable: 'LB_URL'),
            string(credentialsId: 'LIQUIBASE_USERNAME', variable: 'LB_USER'),
            string(credentialsId: 'LIQUIBASE_PASSWORD', variable: 'LB_PASS')
        ]) {
            dir("${WORKSPACE}/liquibase") {
                sh '''
                    echo "=== Running Liquibase Validate ==="
                    export LIQUIBASE_URL="${LB_URL}"
                    export LIQUIBASE_USERNAME="${LB_USER}"
                    export LIQUIBASE_PASSWORD="${LB_PASS}"
                    liquibase validate
                    echo "=== Changelog is VALID — PR can be merged ==="
                '''
            }
        }
    }

    post_build_cleanup()
}

def post_build_cleanup() {
    echo "Pipeline completed with status: ${currentBuild.currentResult}"
}
