@Library('ci-jenkins-shared-libraries@liquibase') _

node('built-in') {
    stage('Git Checkout') {
        checkout scm
    }

    stage('Liquibase Validate') {
        withCredentials([
            string(credentialsId: 'LIQUIBASE_URL',      variable: 'LB_URL'),
            string(credentialsId: 'LIQUIBASE_USERNAME', variable: 'LB_USER'),
            string(credentialsId: 'LIQUIBASE_PASSWORD', variable: 'LB_PASS')
        ]) {
            dir("${WORKSPACE}/liquibase") {
                sh '''
                    echo "=== Running Liquibase Validate ==="
                    liquibase \
                        --url="${LB_URL}" \
                        --username="${LB_USER}" \
                        --password="${LB_PASS}" \
                        --changelog-file=changelog/db.changelog-master.xml \
                        validate
                    echo "=== Changelog is VALID ==="
                '''
            }
        }
    }
}
JENKINS

# Drift Detection fix
cat > resources/jenkinsfiles/liquibase/Jenkinsfile.drift-detection << 'JENKINS'
@Library('ci-jenkins-shared-libraries@liquibase') _

properties([pipelineTriggers([cron('H */6 * * *')])])

node('self-hosted') {
    stage('Git Checkout') {
        checkout scm
    }

    stage('Liquibase Status') {
        withCredentials([
            string(credentialsId: 'LIQUIBASE_URL',      variable: 'LB_URL'),
            string(credentialsId: 'LIQUIBASE_USERNAME', variable: 'LB_USER'),
            string(credentialsId: 'LIQUIBASE_PASSWORD', variable: 'LB_PASS')
        ]) {
            dir("${WORKSPACE}/liquibase") {
                sh '''
                    echo "=== Checking Pending Changesets ==="
                    liquibase \
                        --url="${LB_URL}" \
                        --username="${LB_USER}" \
                        --password="${LB_PASS}" \
                        --changelog-file=changelog/db.changelog-master.xml \
                        status --verbose
                '''
            }
        }
    }

    stage('Detect Unauthorized Drift') {
        withCredentials([
            string(credentialsId: 'LIQUIBASE_URL',      variable: 'LB_URL'),
            string(credentialsId: 'LIQUIBASE_USERNAME', variable: 'LB_USER'),
            string(credentialsId: 'LIQUIBASE_PASSWORD', variable: 'LB_PASS')
        ]) {
            dir("${WORKSPACE}/liquibase") {
                sh '''
                    mkdir -p drift-reports snapshots
                    if [ -f "snapshots/baseline.snapshot.json" ]; then
                        echo "=== Comparing live DB against baseline ==="
                        liquibase \
                            --url="${LB_URL}" \
                            --username="${LB_USER}" \
                            --password="${LB_PASS}" \
                            diff \
                            --reference-url="offline:postgresql?snapshot=snapshots/baseline.snapshot.json" \
                            > drift-reports/drift.txt 2>&1 || true
                        cat drift-reports/drift.txt
                    else
                        echo "=== No baseline snapshot — run Deploy job first ==="
                    fi
                '''
            }
        }
    }

    stage('Publish Drift Report') {
        dir("${WORKSPACE}/liquibase") {
            archiveArtifacts artifacts: 'drift-reports/**', allowEmptyArchive: true
        }
    }
}
