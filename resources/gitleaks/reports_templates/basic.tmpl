<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <title>Gitleaks Security Findings</title>
  <style>
    body {
      font-family: Arial, Helvetica, sans-serif;
      background: #f6f8fa;
      color: #24292e;
      margin: 0;
      padding: 0;
    }

    header {
      background: #2563eb;
      color: #fff;
      padding: 16px 24px;
      font-size: 20px;
      font-weight: bold;
    }

    .container {
      padding: 24px;
    }

    .summary {
      background: #ffffff;
      border: 1px solid #e1e4e8;
      padding: 16px;
      margin-bottom: 24px;
      border-radius: 4px;
    }

    .summary p {
      margin: 6px 0;
    }

    table {
      width: 100%;
      border-collapse: collapse;
      background: #ffffff;
      border: 1px solid #e1e4e8;
    }

    th {
      background: #f3f4f6;
      text-align: left;
      padding: 12px;
      border-bottom: 1px solid #e1e4e8;
      font-size: 14px;
    }

    td {
      padding: 12px;
      border-bottom: 1px solid #e1e4e8;
      vertical-align: top;
      font-size: 13px;
    }

    tr:hover {
      background: #f9fafb;
    }

    .secret {
      background: #fee2e2;
      color: #7f1d1d;
      padding: 6px;
      border-radius: 3px;
      font-family: monospace;
      word-break: break-all;
      display: inline-block;
    }

    .meta {
      font-size: 12px;
      color: #4b5563;
    }

    footer {
      margin-top: 24px;
      font-size: 12px;
      color: #6b7280;
      text-align: right;
    }
  </style>
</head>

<body>

<header>
  Gitleaks Security Findings
</header>

<div class="container">

  <div class="summary">
    <p><strong>Security Scan Report</strong></p>
    <p>Generated on {{now | date "02 Jan 2006 15:04:05 MST"}}</p>
    <p><strong>Total Findings:</strong> {{len .}}</p>
  </div>

  <table>
    <thead>
      <tr>
        <th>Rule</th>
        <th>File</th>
        <th>Description</th>
        <th>Secret</th>
        <th>Metadata</th>
      </tr>
    </thead>
    <tbody>
      {{- range . }}
      <tr>
        <td>{{.RuleID}}</td>
        <td>{{.File}}<br><small>Line: {{.StartLine}}</small></td>
        <td>{{.Description}}</td>
        <td><span class="secret">{{.Secret}}</span></td>
        <td class="meta">
          Entropy: {{printf "%.2f" .Entropy}}<br>
          {{- if .Commit }}Commit: {{printf "%.7s" .Commit}}<br>{{ end -}}
          {{- if .Author }}Author: {{.Author}}<br>{{ end -}}
          {{- if .Date }}Date: {{.Date}}<br>{{ end -}}
          {{- if .Link }}<a href="{{.Link}}" target="_blank">View Commit</a>{{ end -}}
        </td>
      </tr>
      {{- end }}
    </tbody>
  </table>

  <footer>
    Generated by Gitleaks
  </footer>

</div>
</body>
</html>
