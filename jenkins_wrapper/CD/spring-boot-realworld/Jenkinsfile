node {
    ansiColor('xterm') {
        def imageTag = params.image_tag ?: 'latest'
        def gitopsRepo = 'https://github.com/priyanshu499-ops/montra-gitops-manifests.git'
        def valuesFile = 'applications/dev/spring-boot-realworld-values.yaml'

        stage('Checkout GitOps Repo') {
            git url: gitopsRepo, branch: 'main', credentialsId: 'github-token'
        }

        stage('Update Image Tag') {
            sh """
                sed -i 's|tag: .*|tag: "${imageTag}"|' ${valuesFile}
                cat ${valuesFile}
            """
        }

        stage('Commit & Push') {
            withCredentials([usernamePassword(credentialsId: 'github-token', usernameVariable: 'GIT_USER', passwordVariable: 'GIT_TOKEN')]) {
                sh """
                    git config user.email "jenkins@montra.local"
                    git config user.name "Jenkins CD"
                    git add ${valuesFile}
                    git commit -m "deploy: spring-boot-realworld image tag ${imageTag}" || echo "No changes to commit"
                    git push https://\${GIT_USER}:\${GIT_TOKEN}@github.com/priyanshu499-ops/montra-gitops-manifests.git main
                """
            }
        }

        stage('ArgoCD Sync Status') {
            echo "ArgoCD auto-sync enabled — deployment will sync automatically within a few seconds."
        }
    }
}
